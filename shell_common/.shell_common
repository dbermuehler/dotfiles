#--------------------------------------------------#
#                     Variables                    #
#--------------------------------------------------#

export PATH="$PATH:$HOME/bin:$HOME/.local/bin"
export EDITOR=nvim
export VISUAL=nvim
export BC_ENV_ARGS=$HOME/.bcrc
export FZF_DEFAULT_OPTS='--height 75% --reverse'

#--------------------------------------------------#
#                     Aliases                      #
#--------------------------------------------------#

alias ls='ls -G'
alias sl='ls'
alias grep='grep --color=auto'
alias mkdir='mkdir -p'
alias cp='cp -r'
alias nvim='nvim -p'
alias bc='bc -l'
alias doch='su -c "$(history -p !-1)"'
alias htop='htop -d 10' # starts htop with an update intervall of 1000 ms
alias pgrep='pgrep -f'
alias tldrf='tldr --list | fzf --preview "tldr {1} --color=always" --preview-window=right,70% | xargs tldr'

#--------------------------------------------------#
#                    Functions                     #
#--------------------------------------------------#

# draw a horizontal line
hr(){
    yes -- "${@:-"-"}" | tr -d $'\n' | head -c $COLUMNS
}

function cd() {
    if [[ -z "$*" ]]; then
        clear
        builtin cd
    else
        clear
        builtin cd "$@" && pwd && ls;
    fi
}

sp(){
    local COPY_PATH=""
    local DELETE_SCRATCHPAD="false"
    local SCRATCHPAD_NAME
    SCRATCHPAD_NAME=$(date "+%Y-%m-%d")

    while [[ $# -gt 0 ]]; do
        case $1 in
            -d|--delete)
                DELETE_SCRATCHPAD="true"
                shift
                ;;
            -l|--list)
                ls -1 /tmp/scratchpad
                return 0
                ;;
            -h|--help)
                echo "Usage: sp [options] [FILE_OR_DIR]"
                echo "Options:"
                echo "  -d, --delete    Delete today's scratchpad"
                echo "  -l, --list      List all scratchpads in the /tmp/scratchpad dir"
                echo "Arguments:"
                echo "  FILE_OR_DIR     File or directory to copy into the scratchpad"
                return 0
                ;;
            -*|--*)
                echo "Unknown option $1"
                return 1
                ;;
            *)
                COPY_PATH="$1"
                shift
                ;;
        esac
    done

    if [ "$DELETE_SCRATCHPAD" = "true" ]; then
        rm -rf "/tmp/scratchpad/$SCRATCHPAD_NAME"
        echo "Deleting scratchpad $SCRATCHPAD_NAME..."
        return 0
    fi

    if [ ! -d "/tmp/scratchpad/$SCRATCHPAD_NAME" ]; then
        echo "Creating scratchpad $SCRATCHPAD_NAME..."
        command mkdir -p "/tmp/scratchpad/$SCRATCHPAD_NAME"
    fi

    if [ -n "$COPY_PATH" ]; then
        cp -r "$COPY_PATH" "/tmp/scratchpad/$SCRATCHPAD_NAME/"
    fi

    cd "/tmp/scratchpad/$SCRATCHPAD_NAME"
}

json() {
    local FILE=${1:--}
    python3 -m json.tool $FILE
}
